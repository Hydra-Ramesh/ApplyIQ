# ApplyIQ Frontend (React/Vite) Environment Variables
# Copy this file to .env and fill in the values

# The URL of the Node.js API Gateway
VITE_API_URL=https://applyiq-backend-ojhq.onrender.com/api

# The URL of the Python AI Microservice
VITE_AI_URL=https://applyiq-ai-service.onrender.com

# The Stripe Publishable Key for the Checkout UI
VITE_STRIPE_PUBLIC_KEY=pk_test_...
