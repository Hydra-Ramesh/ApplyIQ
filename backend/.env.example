# ApplyIQ Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Config
PORT=5000
FRONTEND_URL=https://apply-iq-vozm.vercel.app

# AI Service Connection (FastAPI)
AI_SERVICE_URL=https://applyiq-ai-service.onrender.com

# Database & Caching
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/applyiq
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Authentication
JWT_SECRET=generate_a_very_long_secure_random_string_here
JWT_EXPIRES_IN=7d

# Stripe (Monetization)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service (Resend)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@applyiq.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
