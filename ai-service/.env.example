# ApplyIQ AI Service (FastAPI) Environment Variables
# Copy this file to .env and fill in the values

# Server Config
PORT=8000
HOST=0.0.0.0

# Groq API Keys (For Llama 3)
# You can provide a comma-separated list of keys for the key rotation manager
GROQ_API_KEYS=gsk_your_first_key_here,gsk_your_second_key_here

# Caching (Upstash / Redis)
# Must match the backend Redis URL so both services share the same cache
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
